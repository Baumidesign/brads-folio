<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Personal Planner</title>
  <style>
    body { background: #09090b; color: #fafafa; font-family: system-ui, -apple-system, sans-serif; padding: 1rem; margin: 0; }
    .header-bar { display: flex; justify-content: flex-end; margin-bottom: 1rem; }
    .container { max-width: 950px; margin: 0 auto; }
    
    .month-nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .month-nav button { background: #27272a; color: white; border: none; padding: 0.6rem 1rem; border-radius: 6px; font-weight: bold; cursor: pointer; transition: 0.2s; }
    .month-nav button:hover { background: #3f3f46; }
    
    .dashboard { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 1rem; }
    .stat-card { background: #18181b; border: 1px solid #27272a; padding: 1.5rem; border-radius: 12px; text-align: center; }
    .stat-card.actual { border-top: 4px solid #2563eb; }
    .stat-card.planned { border-top: 4px solid #60a5fa; }
    .stat-label { font-size: 0.8rem; color: #a1a1aa; text-transform: uppercase; letter-spacing: 1px; }
    .stat-value { font-size: 2.5rem; font-weight: bold; margin-top: 0.5rem; }

    .calendar-header { display: grid; grid-template-columns: repeat(7, 1fr); text-align: center; font-weight: bold; font-size: 0.75rem; color: #71717a; margin-bottom: 5px; }
    .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; background: #27272a; border-radius: 8px; overflow: hidden; margin-bottom: 1rem; }
    .day-box { background: #18181b; min-height: 70px; padding: 5px; cursor: pointer; transition: 0.2s; }
    .day-box:hover { background: #27272a; }
    .hours-actual { background: #2563eb; color: white; font-size: 0.7rem; padding: 2px; border-radius: 4px; margin-top: 2px; text-align: center; font-weight: bold; }
    .hours-planned { border: 1px dashed #60a5fa; color: #60a5fa; font-size: 0.7rem; padding: 2px; border-radius: 4px; margin-top: 2px; text-align: center; }
    
    form { display: flex; flex-direction: column; gap: 10px; background: #18181b; padding: 1.5rem; border-radius: 8px; border: 1px solid #27272a; }
    input, textarea, button.form-btn { padding: 0.8rem; border-radius: 6px; border: 1px solid #3f3f46; background: #09090b; color: white; font-family: inherit; }
    .btn-primary { background: #2563eb; border: none; font-weight: bold; cursor: pointer; color: white; }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-cancel { background: #3f3f46; border: none; font-weight: bold; cursor: pointer; display: none; color: white; }

    .log-item { border-bottom: 1px solid #27272a; padding: 1rem 0; display: flex; justify-content: space-between; align-items: flex-start; }
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(9, 9, 11, 0.8);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      backdrop-filter: blur(4px);
    }
    .modal-content {
      background: #18181b;
      padding: 2rem;
      border-radius: 12px;
      border: 1px solid #27272a;
      max-width: 400px;
      text-align: center;
    }
    .log-item-header {
      font-weight: bold;
      margin-bottom: 4px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .log-item-notes {
      font-size: 0.85rem;
      color: #a1a1aa;
      font-style: italic;
    }
    .log-item-info {
      flex-grow: 1;
    }
    .log-item-hours {
      color: #60a5fa;
    }
    .log-badge.planned { border: 1px dashed #60a5fa; color: #60a5fa; padding: 2px 6px; border-radius: 12px; font-size: 0.7rem; }
    .action-group { display: flex; gap: 8px; }
    .btn-edit { background: transparent; border: 1px solid #3f3f46; color: #fafafa; padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer; }
    .btn-delete { background: transparent; border: 1px solid #ef4444; color: #ef4444; padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer; }

    .toast-container {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 2000;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.75rem;
    }
    .toast {
      padding: 0.75rem 1.25rem;
      border-radius: 8px;
      color: white;
      font-weight: 500;
      box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
      animation: toast-in 0.3s ease-out forwards;
      opacity: 0;
    }
    .toast.fade-out {
      animation: toast-out 0.4s ease-in forwards;
    }
    .toast.success { background-color: #22c55e; }
    .toast.error { background-color: #ef4444; }

    @keyframes toast-in {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes toast-out {
      from {
        opacity: 1;
        transform: translateY(0);
      }
      to {
        opacity: 0;
        transform: translateY(20px);
      }
    }

    /* --- MOBILE RESPONSIVENESS --- */
    @media (max-width: 640px) {
      body {
        padding: 0.5rem; /* Reduce body padding on small screens */
      }
      .container {
        padding: 0 0.5rem; /* Add horizontal padding to the main container */
      }
      .month-nav {
        gap: 0.5rem;
      }
      .month-nav h2 {
        font-size: 1.1rem;
        text-align: center;
      }
      .month-nav button {
        padding: 0.5rem 0.75rem;
      }
      .stat-card {
        padding: 1rem;
      }
      .stat-value {
        font-size: 2rem;
      }
      .day-box {
        min-height: 60px; /* Slightly smaller day boxes */
      }
      .log-item {
        flex-direction: column;
        gap: 0.75rem;
        align-items: flex-start;
      }
      .modal-content {
        width: 90%;
        padding: 1.5rem;
      }
      /* Stack form buttons for better touch targets */
      #plannerForm div:has(> #submitBtn) {
        flex-direction: column-reverse;
        gap: 0.5rem;
      }
    }
  </style>
</head>
<body
  data-access-token={accessToken}
  data-logs={JSON.stringify(viewedMonthLogs || [])}
  data-default-date={defaultDate}
  data-current-year={currentYear}
  data-current-month={currentMonth}
>

  <div id="toast-container" class="toast-container"></div>

  <header class="header-bar">
    <SignOut />
  </header>

  <div class="container">
    <div class="month-nav">
      <button type="button" onclick={`window.location.search='?month=${prevMonth}&year=${prevYear}'`}>&larr; Prev</button>
      <h2 style="margin: 0; display: flex; align-items: center; gap: 10px;">
        {monthName} {currentYear}
        {!isCurrentMonth && <button type="button" onclick="window.location.search=''" style="font-size: 0.7rem; background: #2563eb; padding: 4px 8px; border-radius: 4px;">Today</button>}
      </h2>
      <button type="button" onclick={`window.location.search='?month=${nextMonth}&year=${nextYear}'`}>Next &rarr;</button>
    </div>
    
    <div class="dashboard">
      <div class="stat-card actual">
        <div class="stat-label">Actual Hours</div>
        <div id="monthActualValue" class="stat-value">{monthActual}</div>
      </div>
      <div class="stat-card planned">
        <div class="stat-label">Planned Hours</div>
        <div id="monthPlannedValue" class="stat-value">{monthPlanned}</div>
      </div>
    </div>
    
    <div class="calendar-header">
      <div>S</div><div>M</div><div>T</div><div>W</div><div>T</div><div>F</div><div>S</div>
    </div>
    <div class="calendar-grid" id="calendarGrid">
      {Array.from({ length: firstDayIndex }).map(() => <div class="day-box" style="background: #09090b; cursor: default;"></div>)}
      {Array.from({ length: daysInMonth }).map((_, i) => {
        const day = i + 1;
        const data = hoursByDay[day];
        return (
          <div class="day-box" data-day={day} onclick={`document.getElementById('dateInput').value='${currentYear}-${String(currentMonth+1).padStart(2,'0')}-${String(day).padStart(2,'0')}'`}>
            <span style="font-size: 0.75rem; color: #71717a;">{day}</span>
            {data?.actual > 0 && <div class="hours-actual">{data.actual}h</div>}
            {data?.planned > 0 && <div class="hours-planned">P: {data.planned}h</div>}
          </div>
        )
      })}
    </div>

    <form id="plannerForm">
      <input type="hidden" id="logId" name="id" />
      <div style="display: flex; gap: 10px;">
        <input type="date" id="dateInput" name="date" class="form-btn" required value={defaultDate} style="flex: 2;" />
        <input type="number" id="hoursInput" name="hours" class="form-btn" placeholder="Hrs" step="0.1" required style="flex: 1;" />
      </div>
      <textarea id="notesInput" name="notes" class="form-btn" placeholder="Notes..."></textarea>
      <div style="display: flex; gap: 10px; align-items: center; padding: 0.5rem 0;">
        <input type="checkbox" id="planToggle" name="is_planned" />
        <label for="planToggle">Mark as Planned</label>
      </div>
      <div style="display: flex; gap: 10px;">
        <button type="submit" id="submitBtn" class="form-btn btn-primary" style="flex: 1;">Save Log</button>
        <button type="button" id="cancelBtn" class="form-btn btn-cancel">Cancel Edit</button>
      </div>
    </form>

    <div style="margin-top: 2rem;">
      <h3>Entries for {monthName}</h3>
      <div id="logListContainer">
        {viewedMonthLogs?.length === 0 && <p style="color: #71717a;">No entries for this month.</p>}
        {viewedMonthLogs?.map((log) => (
          <div class="log-item" data-log-id={log.id}>
            <div class="log-item-info">
              <div class="log-item-header">
                <span class="log-item-date">{new Date(log.date).toLocaleDateString('en-AU', { timeZone: 'UTC', weekday: 'short', day: 'numeric', month: 'short' })}</span>
                <span class="log-item-hours">{log.hours} hrs</span>
                {log.is_planned && <span class="log-badge planned">Planned</span>}
              </div>
              {log.notes && <div class="log-item-notes">{log.notes}</div>}
            </div>
            <div class="action-group">
              <button type="button" class="btn-edit" 
                data-id={log.id} data-date={log.date} data-hours={log.hours} 
                data-planned={String(log.is_planned)} data-notes={log.notes || ''}>Edit</button>
              <button type="button" class="btn-delete" data-id={log.id}>Delete</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <template id="log-item-template">
    <div class="log-item">
      <div class="log-item-info">
        <div class="log-item-header">
          <span class="log-item-date"></span>
          <span class="log-item-hours"></span>
          <span class="log-badge planned">Planned</span>
        </div>
        <div class="log-item-notes"></div>
      </div>
      <div class="action-group">
        <button type="button" class="btn-edit">Edit</button>
        <button type="button" class="btn-delete">Delete</button>
      </div>
    </div>
  </template>

  <div id="deleteModal" class="modal-overlay" style="display: none;">
    <div class="modal-content">
      <h4 style="margin-top: 0;">Confirm Deletion</h4>
      <p style="color: #a1a1aa;">Are you sure you want to delete this log entry? This action cannot be undone.</p>
      <div style="display: flex; justify-content: center; gap: 1rem; margin-top: 1.5rem;">
        <button type="button" id="cancelDeleteBtn" class="form-btn btn-cancel" style="display: inline-block; flex: 1;">Cancel</button>
        <button type="button" id="confirmDeleteBtn" class="form-btn" style="background: #ef4444; color: white; flex: 1;">Delete</button>
      </div>
    </div>
  </div>

  <script>
    // Client-side Supabase client initialization
    import { createClient } from '@supabase/supabase-js';
    
    // 1. Grab the VIP pass (token) we attached to the body
    const accessToken = document.body.dataset.accessToken;
    
    // 2. Give it to the Supabase client
    const supabase = createClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
      {
        global: {
          headers: {
            Authorization: `Bearer ${accessToken}`
          }
        }
      }
    );
    
    // --- TYPES ---
    interface PlannerLog {
      id: string;
      date: string;
      hours: number;
      notes: string | null;
      is_planned: boolean;
    }

    document.addEventListener('DOMContentLoaded', () => {
      const body = document.body;
      // --- STATE ---
      let logs: PlannerLog[] = JSON.parse(body.dataset.logs || '[]');
      const defaultDate = body.dataset.defaultDate;
      const currentYear = parseInt(body.dataset.currentYear!, 10);
      const currentMonth = parseInt(body.dataset.currentMonth!, 10);
      let logIdToDelete: string | null = null;
      // --- DOM ELEMENTS ---
      const form = document.getElementById('plannerForm') as HTMLFormElement;
      const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
      const cancelBtn = document.getElementById('cancelBtn') as HTMLButtonElement;
      const deleteModal = document.getElementById('deleteModal') as HTMLDivElement;
      const cancelDeleteBtn = document.getElementById('cancelDeleteBtn') as HTMLButtonElement;
      const confirmDeleteBtn = document.getElementById('confirmDeleteBtn') as HTMLButtonElement;
      const logListContainer = document.getElementById('logListContainer') as HTMLDivElement;
      const monthActualValue = document.getElementById('monthActualValue') as HTMLDivElement;
      const monthPlannedValue = document.getElementById('monthPlannedValue') as HTMLDivElement;
      const calendarGrid = document.getElementById('calendarGrid') as HTMLDivElement;
      const toastContainer = document.getElementById('toast-container') as HTMLDivElement;

      if (!form || !logListContainer || !cancelBtn || !deleteModal) {
        console.error("Essential planner elements could not be found in the DOM. The script will not run.");
        return;
      }

      // --- RENDER FUNCTIONS ---
      function showToast(message: string, type: 'success' | 'error' = 'success') {
        if (!toastContainer) return;
        const toast = document.createElement('div');
        toast.classList.add('toast', type);
        toast.textContent = message;
        toastContainer.appendChild(toast);

        const FADE_DURATION_MS = 400; // Must match the 'toast-out' animation duration
        const VISIBLE_DURATION_MS = 2000;

        setTimeout(() => {
          toast.classList.add('fade-out');
          setTimeout(() => {
            toast.remove();
          }, FADE_DURATION_MS);
        }, VISIBLE_DURATION_MS);
      }

      function createLogElement(log: PlannerLog) {
        const template = document.getElementById('log-item-template') as HTMLTemplateElement;
        if (!template) {
          console.error('The log item template was not found.');
          return document.createElement('div'); // Failsafe
        }

        const clone = template.content.cloneNode(true) as DocumentFragment;
        const logItem = clone.querySelector('.log-item') as HTMLDivElement;
        logItem.dataset.logId = log.id;

        // Populate data
        // The date from DB is YYYY-MM-DD. new Date() will parse this as UTC, which is consistent with server-side rendering.
        (clone.querySelector('.log-item-date') as HTMLElement).textContent = new Date(log.date).toLocaleDateString('en-AU', {
          timeZone: 'UTC', weekday: 'short', day: 'numeric', month: 'short'
        });
        (clone.querySelector('.log-item-hours') as HTMLElement).textContent = `${log.hours || 0} hrs`;

        if (!log.is_planned) {
          clone.querySelector('.log-badge.planned')?.remove();
        }

        if (log.notes) {
          (clone.querySelector('.log-item-notes') as HTMLElement).textContent = log.notes;
        } else {
          clone.querySelector('.log-item-notes')?.remove();
        }

        // Buttons
        const editBtn = clone.querySelector('.btn-edit') as HTMLButtonElement;
        Object.assign(editBtn.dataset, {
          id: log.id,
          date: log.date,
          hours: String(log.hours),
          planned: String(log.is_planned),
          notes: log.notes || '',
        });

        const deleteBtn = clone.querySelector('.btn-delete') as HTMLButtonElement;
        deleteBtn.dataset.id = log.id;

        return logItem;
      }

      function renderLogList() {
        logListContainer.innerHTML = '';
        if (logs.length === 0) {
          logListContainer.innerHTML = `<p style="color: #71717a;">No entries for this month.</p>`;
          return;
        }
        const sortedLogs = [...logs].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
        sortedLogs.forEach(log => {
          const logElement = createLogElement(log);
          logListContainer.appendChild(logElement);
        });
      }

      function updateDashboardAndCalendar() {
        const hoursByDay: Record<number, { actual: number, planned: number }> = {};
        let monthActual = 0;
        let monthPlanned = 0;

        logs.forEach(log => {
          const day = parseInt(log.date.split('-')[2], 10);
          if (!hoursByDay[day]) hoursByDay[day] = { actual: 0, planned: 0 };
          
          const hours = log.hours || 0;
          if (log.is_planned) {
            hoursByDay[day].planned += hours;
            monthPlanned += hours;
          } else {
            hoursByDay[day].actual += hours;
            monthActual += hours;
          }
        });

        monthActualValue.textContent = String(monthActual);
        monthPlannedValue.textContent = String(monthPlanned);

        calendarGrid.querySelectorAll('.day-box[data-day]').forEach(dayBox => {
          const day = parseInt((dayBox as HTMLElement).dataset.day!, 10);
          const data = hoursByDay[day];
          
          dayBox.querySelector('.hours-actual')?.remove();
          dayBox.querySelector('.hours-planned')?.remove();

          if (data?.actual > 0) {
            const el = document.createElement('div');
            el.className = 'hours-actual';
            el.textContent = `${data.actual}h`;
            dayBox.appendChild(el);
          }
          if (data?.planned > 0) {
            const el = document.createElement('div');
            el.className = 'hours-planned';
            el.textContent = `P: ${data.planned}h`;
            dayBox.appendChild(el);
          }
        });
      }

      // --- Cancel Edit Logic ---
      cancelBtn.addEventListener('click', () => {
        form.reset();
        (document.getElementById('logId') as HTMLInputElement).value = '';
        submitBtn.innerText = "Save Log";
        cancelBtn.style.display = "none";
        // Set default date on reset (variable passed from server)
        (document.getElementById('dateInput') as HTMLInputElement).value = defaultDate || '';
      });

      // --- EVENT DELEGATION for Edit/Delete ---
      logListContainer.addEventListener('click', e => {
        const target = e.target as HTMLElement;
        const editBtn = target.closest('.btn-edit') as HTMLButtonElement;
        const deleteBtn = target.closest('.btn-delete') as HTMLButtonElement;

        if (editBtn) {
          (document.getElementById('logId') as HTMLInputElement).value = editBtn.dataset.id || '';
          (document.getElementById('dateInput') as HTMLInputElement).value = editBtn.dataset.date || '';
          (document.getElementById('hoursInput') as HTMLInputElement).value = editBtn.dataset.hours || '';
          (document.getElementById('notesInput') as HTMLTextAreaElement).value = editBtn.dataset.notes || '';
          (document.getElementById('planToggle') as HTMLInputElement).checked = editBtn.dataset.planned === 'true';
          submitBtn.innerText = "Update Log";
          cancelBtn.style.display = "block";
          form.scrollIntoView({ behavior: 'smooth' });
        }

        if (deleteBtn) {
          logIdToDelete = deleteBtn.dataset.id || null;
          if (logIdToDelete) {
            deleteModal.style.display = 'flex';
          }
        }
      });

      // --- MODAL LOGIC ---
      function closeModal() {
        deleteModal.style.display = 'none';
        logIdToDelete = null;
      }
      cancelDeleteBtn.addEventListener('click', closeModal);
      deleteModal.addEventListener('click', (e) => { if (e.target === deleteModal) closeModal(); });

      confirmDeleteBtn.addEventListener('click', async () => {
        if (!logIdToDelete) return;

        const { error } = await supabase.from('planner_logs').delete().eq('id', logIdToDelete);
        if (error) {
        showToast("Error: " + error.message, 'error');
        } else {
        showToast('Log entry deleted successfully.');
          logs = logs.filter(log => log.id !== logIdToDelete);
          renderLogList();
          updateDashboardAndCalendar();
        }
        closeModal();
      });

      // --- SAVE/UPDATE LOGIC ---
      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const id = formData.get('id');
        
        const payload = { 
          date: formData.get('date') as string,
          // Ensure we don't send NaN to the database if the input is empty
          hours: parseFloat(formData.get('hours') as string) || 0,
          notes: formData.get('notes') as string,
          is_planned: formData.get('is_planned') === 'on'
        };

        let result;
        if (id) {
          result = await supabase.from('planner_logs').update(payload).eq('id', id).select().single();
        } else {
          result = await supabase.from('planner_logs').insert(payload).select().single();
        }

        const { data: newOrUpdatedLog, error } = result;

        if (error) {
          showToast(`Error: ${error.message}`, 'error');
        } else if (newOrUpdatedLog) {
          const isDifferentMonth = !newOrUpdatedLog.date.startsWith(`${currentYear}-${String(currentMonth + 1).padStart(2, '0')}`);
          const isUpdate = !!id;

          if (isDifferentMonth) {
            // If the log was moved to a different month, a reload is the simplest way to handle it
            location.reload();
          } else {
            if (id) { // Update
              const index = logs.findIndex(log => log.id === id);
              if (index !== -1) logs[index] = newOrUpdatedLog;
            } else { // Create
              logs.push(newOrUpdatedLog);
            }
            showToast(isUpdate ? 'Log updated successfully.' : 'Log saved successfully.');
            renderLogList();
            updateDashboardAndCalendar();
            cancelBtn.click(); // Resets the form and button text
          }
        }
      });
    });
  </script>
</body>
</html>
import { supabase } from '../lib/supabase';
import SignOut from '../components/SignOut.astro';

// --- 1. AUTHENTICATION GUARD ---
const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;

if (!accessToken || !refreshToken) {
  return Astro.redirect('/login');
}

let data, authError;
try {
  // Authenticate the Supabase client for this server-side request
  ({ data, error: authError } = await supabase.auth.setSession({
    access_token: accessToken,
    refresh_token: refreshToken,
  }));
} catch (e) {
  console.error('PLANNER_PAGE_SUPABASE_ERROR:', e);
  // This error is likely due to server misconfiguration (missing env vars).
  // Clear cookies and redirect to login to prevent a redirect loop.
  Astro.cookies.delete('sb-access-token', { path: '/' });
  Astro.cookies.delete('sb-refresh-token', { path: '/' });
  return Astro.redirect('/login?error=Server configuration error.');
}

if (authError || !data.user) {
  Astro.cookies.delete('sb-access-token', { path: '/' });
  Astro.cookies.delete('sb-refresh-token', { path: '/' });
  return Astro.redirect('/login');
}

const { user } = data;

// If the session was refreshed, update the cookies to keep the user logged in
if (data.session) {
  const { access_token, refresh_token, expires_in } = data.session;
  Astro.cookies.set('sb-access-token', access_token, {
    path: '/',
    maxAge: Math.round(expires_in),
    sameSite: 'lax',
    secure: import.meta.env.PROD,
  });
  Astro.cookies.set('sb-refresh-token', refresh_token, {
    path: '/',
    maxAge: 60 * 60 * 24 * 30, // 30 days
    sameSite: 'lax',
    secure: import.meta.env.PROD,
  });
}
// --- 2. CALENDAR & NAVIGATION LOGIC ---
const urlMonth = Astro.url.searchParams.get('month');
const urlYear = Astro.url.searchParams.get('year');

const now = new Date();
const currentYear = urlYear !== null ? parseInt(urlYear) : now.getFullYear();
const currentMonth = urlMonth !== null ? parseInt(urlMonth) : now.getMonth();

const prevMonth = currentMonth === 0 ? 11 : currentMonth - 1;
const prevYear = currentMonth === 0 ? currentYear - 1 : currentYear;
const nextMonth = currentMonth === 11 ? 0 : currentMonth + 1;
const nextYear = currentMonth === 11 ? currentYear + 1 : currentYear;

const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
const firstDayIndex = new Date(currentYear, currentMonth, 1).getDay();
const monthName = new Date(currentYear, currentMonth, 1).toLocaleString('default', { month: 'long' });

const isCurrentMonth = now.getMonth() === currentMonth && now.getFullYear() === currentYear;
const defaultDate = isCurrentMonth 
  ? now.toISOString().split('T')[0] 
  : `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-01`;

// --- 3. DATA FETCHING (USER & MONTH SPECIFIC) ---
const firstDayOfMonth = `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-01`;
const lastDayOfMonth = `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-${String(daysInMonth).padStart(2, '0')}`;

const { data: viewedMonthLogs } = await supabase
  .from('planner_logs')
  .select('*')
  // .eq('user_id', user.id) // This filter is now handled by RLS, but can be kept for clarity.
  .gte('date', firstDayOfMonth)
  .lte('date', lastDayOfMonth)
  .order('date', { ascending: false });

// --- 4. CALCULATE TOTALS ---
const hoursByDay: Record<number, { actual: number, planned: number }> = {};
let monthActual = 0;
let monthPlanned = 0;

viewedMonthLogs?.forEach(log => {
  const day = parseInt(log.date.split('-')[2], 10);
  if (!hoursByDay[day]) hoursByDay[day] = { actual: 0, planned: 0 };
  
  if (log.is_planned) {
    hoursByDay[day].planned += log.hours;
    monthPlanned += log.hours;
  } else {
    hoursByDay[day].actual += log.hours;
    monthActual += log.hours;
  }
});


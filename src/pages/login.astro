---
// src/pages/login.astro
---

<html lang="en">
<head>
  <title>Login | Baumi Planner</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    body { background: #09090b; color: #fafafa; font-family: system-ui; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
    .login-card { background: #18181b; padding: 2.5rem; border-radius: 12px; border: 1px solid #27272a; width: 100%; max-width: 350px; text-align: center; box-shadow: 0 10px 25px rgba(0,0,0,0.5); }
    h1 { margin-top: 0; font-size: 1.5rem; margin-bottom: 1.5rem; }
    form { display: flex; flex-direction: column; gap: 1rem; }
    input { padding: 0.8rem; border-radius: 6px; border: 1px solid #3f3f46; background: #09090b; color: white; font-family: inherit; font-size: 1rem; }
    button { background: #2563eb; color: white; border: none; padding: 0.8rem; border-radius: 6px; font-weight: bold; cursor: pointer; transition: 0.2s; font-size: 1rem; }
    button:hover { background: #1d4ed8; }
    #error-msg { color: #ef4444; font-size: 0.85rem; margin-top: 1rem; min-height: 20px; }
  </style>
</head>
<body>
  <div class="login-card">
    <h1>Welcome Back</h1>
    <form id="loginForm">
      <input type="email" name="email" placeholder="Email" required />
      <input type="password" name="password" placeholder="Password" required />
      <button type="submit" id="submitBtn">Sign In</button>
    </form>
    <div id="error-msg"></div>
  </div>

  <script>
    // Client-side Supabase client initialization
    import { createClient } from '@supabase/supabase-js';
    const supabase = createClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY
    );

    const form = document.getElementById('loginForm') as HTMLFormElement;
    const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.innerText = "";
      submitBtn.innerText = "Signing in...";
      
      const formData = new FormData(form);
      const email = formData.get('email') as string;
      const password = formData.get('password') as string;

      // 1. Authenticate with Supabase
      const { data, error } = await supabase.auth.signInWithPassword({ email, password });

      if (error) {
        errorMsg.innerText = error.message;
        submitBtn.innerText = "Sign In";
        return;
      }

      // 2. Save the session tokens as Cookies so Astro's server can read them
      if (data.session) {
        document.cookie = `sb-access-token=${data.session.access_token}; path=/; max-age=2592000; SameSite=Lax; secure`;
        document.cookie = `sb-refresh-token=${data.session.refresh_token}; path=/; max-age=2592000; SameSite=Lax; secure`;
        
        // 3. Redirect to the planner
        window.location.href = '/planner';
      }
    });
  </script>
</body>
</html>
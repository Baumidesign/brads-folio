---
// src/pages/login.astro

// If the user is already logged in, redirect them to the planner.
const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;

if (accessToken && refreshToken) {
  // A simple check is enough here. The planner page will do the full validation.
  return Astro.redirect('/planner');
}

// Get error message from URL query parameters, e.g. /login?error=Invalid%20credentials
const error = Astro.url.searchParams.get('error');
---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Personal Planner</title>
  <style>
    body { background: #09090b; color: #fafafa; font-family: system-ui, -apple-system, sans-serif; display: grid; place-content: center; min-height: 100vh; margin: 0; }
    .login-card { background: #18181b; border: 1px solid #27272a; padding: 2.5rem; border-radius: 12px; width: 350px; }
    h1 { text-align: center; margin-top: 0; }
    form { display: flex; flex-direction: column; gap: 1rem; }
    label { font-size: 0.9rem; color: #a1a1aa; }
    input { padding: 0.8rem; border-radius: 6px; border: 1px solid #3f3f46; background: #09090b; color: white; font-family: inherit; font-size: 1rem; }
    button { padding: 0.8rem; border-radius: 6px; border: none; background: #2563eb; color: white; font-weight: bold; cursor: pointer; transition: 0.2s; font-size: 1rem; }
    button:hover { background: #1d4ed8; }
    .error-message { background: #ef444420; border: 1px solid #ef4444; color: #fca5a5; padding: 0.8rem; border-radius: 6px; text-align: center; margin-top: 1.5rem; }
  </style>
</head>
<body>
  <div class="login-card">
    <h1>Planner Login</h1>
    <form method="post" action="/api/auth/signin">
      <div>
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required />
      </div>
      <div>
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required />
      </div>
      <button type="submit">Sign In</button>
    </form>
    {error && <div class="error-message">{error}</div>}
  </div>
</body>
</html>